# ── Shared (export.mjs + import.mjs + backup.mjs) ────────────────────────────
# CMA token — used by all three scripts (export now uses CMA too).
# Get it: https://app.contentful.com → avatar (top-right) → Content management tokens
# NEVER commit the real token — fill this in locally only.
CONTENTFUL_MANAGEMENT_TOKEN=your-cma-token-here

# Override the target environment (default: master)
# CONTENTFUL_ENVIRONMENT=staging

# Locale codes — must match exactly what's registered in your Contentful space
# Check: Settings → Locales
LOCALE_SOURCE=en-US
LOCALE_TARGET=zh-CN
