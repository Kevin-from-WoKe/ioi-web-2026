# ── export.mjs ───────────────────────────────────────────────────────────────
# No .env needed for export — uses the public CDA token baked into the script.

# ── import.mjs ───────────────────────────────────────────────────────────────
# Requires a Content Management API token to write translations back.
# Get it: https://app.contentful.com → avatar (top-right) → Content management tokens
# NEVER commit the real token — fill this in locally only.
CONTENTFUL_MANAGEMENT_TOKEN=your-cma-token-here
