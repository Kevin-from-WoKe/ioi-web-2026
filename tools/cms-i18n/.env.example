# Contentful Management API token
# Get it from: https://app.contentful.com → Settings → API Keys → Content management tokens
# NEVER commit the real token — this file is the template only.
CONTENTFUL_MANAGEMENT_TOKEN=your-cma-token-here

# These match cms-config.js (already public, safe to copy here)
CONTENTFUL_SPACE_ID=slmipam661bk
CONTENTFUL_ENVIRONMENT=master

# Source locale (what to export)
LOCALE_SOURCE=en-US

# Target locale (what to translate into)
LOCALE_TARGET=zh-Hans
