    },
    {
      "id": "t60",
      "type": "text",
      "context": "div.w-layout-grid > div#w-node-_0a67f569-b321-004f-3b43-eac75488579d-8392438b > p",
      "en": "We ensure fair labour practices and respect for workers throughout our supply chain.",
      "cn": "在整条供应链中确保公平劳动实践与对工人的尊重。"
    },
    {
