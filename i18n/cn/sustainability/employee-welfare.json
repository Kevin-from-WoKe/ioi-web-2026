    {
      "id": "t39",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > div.text-style-tagline",
      "en": "Safe Workplace",
      "cn": "安全职场"
    },
    {
      "id": "t40",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > h3.heading-style-h4",
      "en": "Ethical workspace",
      "cn": "合乎道德的工作环境"
    },
    {
      "id": "t41",
      "type": "text",
      "context": "div.w-layout-grid > div.layout231_item > p",
      "en": "We partner with SMETA to ensure ethical, legally compliant operations that eliminate slavery and child labour while maintaining safe working environments. We're committed to zero safety incidents through comprehensive equipment, training and monitoring of safety indicators. Details are available on our corporate website.",
      "cn": "我们与 SMETA 合作，确保运营合乎道德与法律规范，杜绝奴役和童工，同时维护安全的工作环境。我们以全面的设备、培训与安全指标监测，致力实现零安全事故。详情请见我们的企业网站。"
    },
    {
      "id": "t42",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > div.text-style-tagline",
      "en": "Safe Workplace",
      "cn": "安全职场"
    },
    {
      "id": "t43",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > h3.heading-style-h4",
      "en": "Vision zero 3E+3S",
      "cn": "零事故愿景 3E+3S"
    },
    {
      "id": "t44",
      "type": "text",
      "context": "div.w-layout-grid > div.layout231_item > p",
      "en": "We are committed to fostering a robust safety culture through its 3E framework—Engagement, Empowerment and Enforcement—which aligns with the 3S theme (Sihat, Selamat, Semangat) under Vision Zero Malaysia. This strategic initiative seeks to minimize occupational accidents and workplace illness by cultivating organisational commitment to accident prevention.",
      "cn": "我们致力构建坚实的安全文化，依托 3E 框架——参与（Engagement）、赋能（Empowerment）与执行（Enforcement），并与马来西亚零事故愿景下的 3S 主题（Sihat 健康、Selamat 安全、Semangat 活力）一致。此战略举措旨在通过培育组织对事故预防的承诺，最大限度降低工伤事故与职业病。"
    },
    {
      "id": "t45",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > div.text-style-tagline",
      "en": "Safe Workplace",
      "cn": "安全职场"
    },
    {
      "id": "t46",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > h3.heading-style-h4",
      "en": "Safety trainings",
      "cn": "安全培训"
    },
    {
      "id": "t47",
      "type": "text",
      "context": "div.w-layout-grid > div.layout231_item > p",
      "en": "We deliver comprehensive safety training programmes for new hires and refresher courses for existing personnel. Our Safe Handling of Chemicals and Spillage Management curriculum includes hands-on spill simulations where employees practice response procedures in full protective equipment, strengthening preparedness for chemical incidents.",
      "cn": "我们为新员工提供全面安全培训课程，并为在职人员开设进修课程。化学品安全处理与泄漏管理课程包含实操泄漏演练，员工在全套防护装备下模拟应对程序，强化化学品事故应急能力。"
    },
    {
      "id": "t48",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > div.text-style-tagline",
      "en": "Healthy Lifestyle",
      "cn": "健康生活"
    },
    {
      "id": "t49",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > h3.heading-style-h4",
      "en": "Preventive care and occupational health support",
      "cn": "预防保健与职业健康支持"
    },
    {
      "id": "t50",
      "type": "text",
      "context": "div.w-layout-grid > div.layout231_item > p",
      "en": "Promoting a healthy lifestyle requires nutrition and wellness awareness. We partner with local healthcare authorities to organise health programmes and blood donation campaigns for employees.",
      "cn": "推广健康生活方式需要营养与养生意识。我们与本地卫生机构合作，为员工举办健康讲座与献血活动。"
    },
    {
      "id": "t51",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > div.text-style-tagline",
      "en": "Sport facilities/Activities",
      "cn": "运动设施／活动"
    },
    {
      "id": "t52",
      "type": "text",
      "context": "div.layout231_item > div.margin-bottom > h3.heading-style-h4",
      "en": "Sports facilities that strengthen workplace bonds",
      "cn": "凝聚团队情谊的运动设施"
    },
    {
      "id": "t53",
      "type": "text",
      "context": "div.w-layout-grid > div.layout231_item > p",
      "en": "We established an in-house sports complex with badminton and squash courts, table tennis and a gymnasium to promote employee wellness and productivity. Our initiatives include an annual badminton tournament, inter-company football matches and team-building events through the IOI Sport & Recreational Club.",
      "cn": "我们设立了内部运动综合中心，包含羽毛球与壁球场地、乒乓球室及健身房，旨在促进员工健康与工作效率。常规活动涵盖每年举办的羽毛球锦标赛、跨公司足球赛，以及通过 IOI 体育与康乐俱乐部组织的团建活动。"
    },
